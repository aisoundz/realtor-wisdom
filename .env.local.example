# Supabase — Project Settings → API
# URL: top of the API page, looks like https://<ref-id>.supabase.co
# Publishable key: starts with sb_publishable_  (safe to expose; use everywhere RLS is on)
# Secret key: starts with sb_secret_  (server-only; bypasses RLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Anthropic — console.anthropic.com → API keys
ANTHROPIC_API_KEY=

# Public site URL — set to https://realtorwisdom.io in Vercel production env
NEXT_PUBLIC_SITE_URL=http://localhost:3000
